# ===== Licenca KLIVA (comprador) =====
KLIVA_LICENSE_KEY=
# Opcional: validacao online (se o vendedor fornecer API)
# KLIVA_LICENSE_URL=https://sua-api.com/validate

# ===== Desenvolvedor (NAO enviar ao comprador) =====
# Usado ao gerar releases e licencas: npm run release / npm run license:generate
# LICENSE_SIGNING_SECRET=

# ===== Browser =====
HEADLESS=false
KEEP_BROWSER_OPEN=false
# true = janela fora da tela (headful, Turnstile/trial funcionam)
HIDE_WINDOWS=false
# Perfil Chrome novo a cada conta (evita abrir ja logado de outra conta)
CHROME_FRESH_PROFILE=true

# caminho manual do chrome.exe (opcional)
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
LOCALE=pt-BR
TIMEZONE=America/Sao_Paulo
ACCEPT_LANGUAGE=pt-BR,pt;q=0.9,en-US;q=0.8,en;q=0.7

# ===== Concorrencia =====
CONCURRENCY=1
INSTANCE_STAGGER_MS=800
MAX_RETRIES_PER_ACCOUNT=1

# ===== Proxy =====
# formato: usuario:senha@host:porta  (NAO coloque a URL em PROXY_SESSION_TEMPLATE)
PROXY_URL=
PROXY_STICKY=true
PROXY_SESSION_TEMPLATE={user}-session-{session}
# Timeout (ms) e retries na verificacao HTTPS da proxy (evita falso timeout no cold start do Chrome)
PROXY_VERIFY_TIMEOUT_MS=45000
PROXY_VERIFY_RETRIES=2
# true = testa HTTPS da proxy antes do login (mais lento). false = vai direto pro login.
PROXY_VERIFY_ON_START=false
# Otimizacoes com proxy residencial (Lightning etc.)
PROXY_MAX_CONCURRENCY=10
PROXY_NAV_TIMEOUT_MS=45000
PROXY_LOGIN_POST_SUBMIT_MS=75000
PROXY_LOGIN_POLL_MS=100
PROXY_LOGIN_SELECTOR_TIMEOUT_MS=10000
PROXY_TRIAL_CHECK_MS=8000
PROXY_INSTANCE_STAGGER_MS=1500
# Bloqueia imagens/fontes/media/websocket fora de login (x.ai), Cloudflare Turnstile e Stripe
PROXY_BLOCK_HEAVY_RESOURCES=true
# Agressivo: bloqueia CSS no grok.com (pode quebrar cliques — use só se precisar economizar mais)
# PROXY_BLOCK_STYLESHEETS=false
PROXY_KEEP_PROFILE=true
# Liga/desliga a proxy por bot (independente). CLI --proxy / --no-proxy sobrescreve.
LOGIN_USE_PROXY=true       # alias: PIX_USE_PROXY
PIX_USE_PROXY=true         # bot de login (npm run pix)

# ===== Grok / login =====
GROK_LOGIN_URL=https://accounts.x.ai/sign-in?redirect=grok-com
# Slug pos-login do SSO x.ai (so vale se GROK_LOGIN_URL nao estiver setado).
# Padrao: grok-com (= home). Variantes tipo grok-com-subscribe nao sao documentadas — teste por conta propria.
# GROK_LOGIN_REDIRECT=grok-com
GROK_POST_LOGIN_URL=https://grok.com
GROK_LOGGED_IN_URL_HINT=grok.com

# ===== Dados =====
ACCOUNTS_FILE=data/accounts.txt
RESULTS_FILE=data/results.json

# ===== Timeouts =====
DEFAULT_TIMEOUT=45000
NAV_TIMEOUT=30000
POLL_MS=100
LOGIN_POLL_MS=250
LOGIN_POST_SUBMIT_MS=60000
TRIAL_CHECK_MS=15000
# URLs extras para buscar trial (vazio = home + /plans + accounts.x.ai/account)
# TRIAL_CHECK_URLS=https://grok.com,https://grok.com/plans

# ===== Output =====
LOG_LEVEL=info
# true = so resumo por conta (login / trial / pix) + erros
SIMPLE_LOGS=false
SCREENSHOT_ON_ERROR=true
SCREENSHOT_DIR=screenshots

# ===== Trial PIX (pos-login) =====
SUBSCRIBE_TRIAL=false
# Pagadores dinamicos (1 bloco RESULTADO = 10 contas; depois remove do arquivo)
PAYER_RESULTS_FILE=data/payer-results.txt
PAYER_ACCOUNTS_PER_RESULT=10
# Fallback se PAYER_RESULTS_FILE vazio (legado)
PIX_PAYER_NAME=JUNIOR GOMES
PIX_PAYER_CPF=00359319904
PIX_WAIT_MS=30000
# Tempo maximo aguardando QR aparecer apos clicar "Revelar codigo QR" (Stripe pode demorar)
PIX_GENERATE_WAIT_MS=90000
# true = voce clica em "Revelar codigo QR" manualmente (util para testar se o Stripe bloqueia o browser)
PIX_MANUAL_REVEAL=false

# 0 = auto (~26s com CONCURRENCY=8). Ms na tela #subscribe clicando plano trial.
# TRIAL_PLAN_ADVANCE_MS=0
# Retentativas quando aparece "Ops, algo deu errado..." ao clicar Solicitar oferta
# Retentativas no plano trial (toast "algo deu errado"). 0 = ate TRIAL_PLAN_ADVANCE_MS.
SUBSCRIBE_ERROR_MAX_RETRIES=0
# Pausa entre cliques em "Solicitar oferta de $0.00" (ms)
SUBSCRIBE_ERROR_RETRY_MS=6000
# false = aguarda pagamento confirmado (obrigatorio para contas prontas). true = modo rapido sem confirmar.
RELEASE_BROWSER_AFTER_PIX=false
# true = mantem browser aberto ate pagamento confirmado no Stripe.
WAIT_FOR_PIX_PAYMENT=true
# So usado se WAIT_FOR_PIX_PAYMENT=true. 0=infinito ate pagar; 1=libera apos um ciclo sem pagamento.
PAYMENT_WAIT_MAX_CYCLES=0
# Arquivos cumulativos de saida (contagem + emails que pagaram)
PAID_COUNT_FILE=data/paid-count.txt
PAID_EMAILS_FILE=data/paid-emails.txt

# Selectors checkout (preencher apos npm run probe:subscribe)
# SEL_TRIAL_CTA=
# SEL_TRIAL_CARD=[data-testid="plan-cta-supergrok"]
# SEL_PAYMENT_PIX=[data-testid="pix-accordion-item-button"]
# SEL_REVEAL_QR=[data-testid="hosted-payment-submit-button"]
# SEL_PAYER_NAME=
# SEL_PAYER_CPF=
# SEL_SUBSCRIBE_SUBMIT=
# SEL_PIX_COPY=
# SEL_PIX_QR=canvas, img[alt*="QR" i]

# ===== WhatsApp (Baileys — gratuito, nativo) =====
WHATSAPP_ENABLED=true
WHATSAPP_FAIL_SOFT=true
# Retentativas se a conexao cair (ex.: VPN ligada no meio do run)
WHATSAPP_SEND_RETRIES=3
WHATSAPP_PROVIDER=baileys
WHATSAPP_AUTH_DIR=whatsapp-auth
# DDI+DDD+numero, so digitos (ex: 5511999999999)
WHATSAPP_PHONE_NUMBER=
# JID do grupo (...@g.us) — legado; grupos sao gerenciados em /grupos (data/whatsapp-groups.json)
WHATSAPP_GROUP_ID=
# Comandos no grupo: /start /stop /status (servidor KLIVA precisa estar rodando)
WHATSAPP_COMMANDS_ENABLED=true
# true = qualquer membro do grupo pode usar /start /stop /status
WHATSAPP_COMMANDS_PUBLIC=false
# Numeros autorizados (DDI+DDD+numero, virgula). Padrao: WHATSAPP_PHONE_NUMBER
WHATSAPP_ADMIN_PHONES=

# legado: Evolution API (self-hosted) ou webhook n8n
# WHATSAPP_PROVIDER=evolution
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=
# EVOLUTION_INSTANCE=
# WHATSAPP_WEBHOOK_URL=
